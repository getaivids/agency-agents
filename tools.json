{
  "_note": "OmniRoster music-business-specific tool definitions. Each tool includes API endpoints, authentication methods, and rate limits. Sources referenced from Artist Management, Music Business, and DJ Business Plan PDFs.",
  "tools": {
    "spotify-for-artists-api": {
      "id": "spotifyArtists",
      "label": "Spotify for Artists API",
      "category": "Analytics",
      "purpose": "Stream data, audience demographics, playlist adds",
      "source": "Artist Mgmt Ch. 11",
      "auth": "OAuth 2.0 (Client Credentials)",
      "endpoints": {
        "base": "https://api.spotify.com/v1",
        "tracks": "/tracks/{id}",
        "artist": "/artists/{id}",
        "top-tracks": "/artists/{id}/top-tracks",
        "related-artists": "/artists/{id}/related-artists"
      },
      "rate_limits": {
        "requests_per_second": 50,
        "daily_quota": 100000
      }
    },
    "chartmetric-api": {
      "id": "chartmetric",
      "label": "Chartmetric API",
      "category": "Analytics",
      "purpose": "Cross-platform tracking, TikTok virality, radio spins",
      "source": "Music Biz: Airplay",
      "auth": "API Key (Bearer Token)",
      "endpoints": {
        "base": "https://api.chartmetric.com",
        "artist": "/artist/{id}",
        "playlist-adds": "/playlist/adds",
        "radio-spins": "/radio/spins",
        "tiktok-virality": "/social/tiktok/trending"
      },
      "rate_limits": {
        "requests_per_minute": 60,
        "monthly_quota": 50000
      }
    },
    "ascap-bmi-soundexchange": {
      "id": "proRegistry",
      "label": "ASCAP/BMI/SoundExchange Registry",
      "category": "Rights",
      "purpose": "PRO cue sheet submission, royalty verification",
      "source": "Music Biz: PRO",
      "auth": "API Key + Member ID",
      "endpoints": {
        "ascap": "https://api.ascap.com/iswc/register",
        "bmi": "https://api.bmi.com/works/register",
        "soundexchange": "https://api.soundexchange.com/isrc/submit"
      },
      "rate_limits": {
        "submissions_per_day": 1000,
        "queries_per_hour": 500
      }
    },
    "docusign-api": {
      "id": "docusign",
      "label": "DocuSign API",
      "category": "Legal",
      "purpose": "Contract execution with audit trail",
      "source": "Artist Mgmt Ch. 7",
      "auth": "OAuth 2.0 (JWT Grant)",
      "endpoints": {
        "base": "https://www.docusign.net/restapi/v2.1",
        "envelopes": "/accounts/{accountId}/envelopes",
        "templates": "/accounts/{accountId}/templates",
        "status": "/accounts/{accountId}/envelopes/{envelopeId}"
      },
      "rate_limits": {
        "requests_per_minute": 1000,
        "envelopes_per_day": 5000
      }
    },
    "quickbooks-api": {
      "id": "quickbooks",
      "label": "QuickBooks API",
      "category": "Finance",
      "purpose": "P&L, invoicing, deposit tracking, recoupment",
      "source": "DJ Plan: Financial",
      "auth": "OAuth 2.0 (3-legged)",
      "endpoints": {
        "base": "https://quickbooks.api.intuit.com/v3/company/{realmId}",
        "invoices": "/invoice",
        "payments": "/payment",
        "reports": "/reports/profitandloss"
      },
      "rate_limits": {
        "requests_per_second": 10,
        "daily_quota": 25000
      }
    },
    "rekordbox-serato-api": {
      "id": "djSoftware",
      "label": "Rekordbox/Serato API",
      "category": "Creative",
      "purpose": "Crate analysis, BPM/key extraction, play history",
      "source": "DJ Plan: Services",
      "auth": "Local File System Access",
      "endpoints": {
        "rekordbox_db": "~/Library/Application Support/Pioneer/rekordbox/export.db",
        "serato_db": "~/Music/_Serato_/database.serato2",
        "export_format": "JSON/XML"
      },
      "rate_limits": {
        "file_reads_per_hour": 100
      }
    },
    "beatport-api": {
      "id": "beatport",
      "label": "Beatport API",
      "category": "Creative",
      "purpose": "Track metadata, label releases, genre trending",
      "source": "Music Biz: Charts",
      "auth": "OAuth 1.0a",
      "endpoints": {
        "base": "https://oauth-api.beatport.com",
        "tracks": "/catalog/3/tracks",
        "releases": "/catalog/3/releases",
        "genres": "/catalog/3/genres"
      },
      "rate_limits": {
        "requests_per_minute": 60
      }
    },
    "songkick-bandsintown": {
      "id": "tourData",
      "label": "Songkick/Bandsintown API",
      "category": "Touring",
      "purpose": "Venue scraping, routing, competitor gig tracking",
      "source": "Artist Mgmt Ch. 10",
      "auth": "API Key",
      "endpoints": {
        "songkick_base": "https://api.songkick.com/api/3.0",
        "songkick_events": "/events.json",
        "songkick_venues": "/venues/{id}.json",
        "bandsintown_base": "https://rest.bandsintown.com/artists",
        "bandsintown_events": "/{artist_name}/events"
      },
      "rate_limits": {
        "requests_per_second": 2,
        "daily_quota": 10000
      }
    },
    "airtable-tour-tracker": {
      "id": "airtable",
      "label": "Airtable Tour Tracker",
      "category": "Ops",
      "purpose": "Master gig database, status state machine",
      "source": "DJ Plan: Operations",
      "auth": "Bearer Token (Personal Access Token)",
      "endpoints": {
        "base": "https://api.airtable.com/v0/{baseId}",
        "gigs_table": "/Gigs",
        "contracts_table": "/Contracts",
        "expenses_table": "/Expenses"
      },
      "rate_limits": {
        "requests_per_second": 5,
        "records_per_request": 100
      }
    },
    "canva-video-ai": {
      "id": "canva",
      "label": "Canva Video AI",
      "category": "Marketing",
      "purpose": "EPK updates, social content, highlight reels",
      "source": "DJ Plan: Marketing",
      "auth": "OAuth 2.0",
      "endpoints": {
        "base": "https://api.canva.com/v1",
        "designs": "/designs",
        "exports": "/exports",
        "templates": "/templates"
      },
      "rate_limits": {
        "requests_per_minute": 100,
        "exports_per_hour": 50
      }
    }
  }
}
